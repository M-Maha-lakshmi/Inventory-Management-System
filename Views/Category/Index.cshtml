@model IEnumerable<InventoryManagementSystem.Entities.Category>

<div class="container mt-4">

    <h2>Categories</h2>

    <a href="/Category/Create" class="btn btn-primary mb-3">Add Category</a>

    <table class="table table-bordered">

        <thead class="table-dark">
            <tr>
                <th>Category Name</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var cat in Model)
            {
                <tr>
                    <td>@cat.CategoryName</td>

                    <td>
                        <a class="btn btn-warning btn-sm" href="/Category/Edit/@cat.Id">Edit</a>

                        <a class="btn btn-danger btn-sm"
                           href="/Category/Delete/@cat.Id"
                           onclick="return confirm('Delete category?')">Delete</a>
                    </td>

                </tr>
            }

        </tbody>

    </table>
    <nav class="mt-3">
        <ul class="pagination justify-content-end">

            <!-- Previous Button -->
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="/Inventory/Index?page=@(ViewBag.CurrentPage - 1)">
                    &laquo; Previous
                </a>
            </li>

            <!-- Page Numbers -->
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="/Inventory/Index?page=@i">@i</a>
                </li>
            }

            <!-- Next Button -->
            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" href="/Inventory/Index?page=@(ViewBag.CurrentPage + 1)">
                    Next &raquo;
                </a>
            </li>

        </ul>
    </nav>

</div>